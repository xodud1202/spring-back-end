<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
		"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.xodud1202.springbackend.mapper.SiteInfoMapper">
	<select id="getShopSiteInfo" resultType="com.xodud1202.springbackend.domain.shop.site.ShopSiteInfoVO">
		/* SiteInfoMapper.getShopSiteInfo: 쇼핑몰 사이트 기본 정보 조회 */
		SELECT SITE_ID
		     , SITE_NM
		  FROM SITE_INFO
		 WHERE SITE_ID = #{siteId}
	</select>
</mapper>
